                "vendor.noth.hardware.camera-V1-ndk",
                "libc",
                "libm",
                "libdl",
            ],
        },
    },
    compile_multilib: "64",
    strip: {
        none: true,
    },
    prefer: true,
    relative_install_path: "hw",
    soc_specific: true,
}

prebuilt_etc_xml {
    name: "vendor.noth.hardware.camera-service.xml",
    owner: "nothing",
    src: "proprietary/vendor/etc/vintf/manifest/vendor.noth.hardware.camera-service.xml",
    filename_from_src: true,
    sub_dir: "vintf/manifest",
    soc_specific: true,
}

// System/Apps prebuilts

android_app_import {
    name: "NothingProxy",
    owner: "nothing",
    apk: "proprietary/system_ext/app/NothingProxy/NothingProxy.apk",
    certificate: "platform",
    dex_preopt: {
        enabled: false,
    },
    system_ext_specific: true,
}

android_app_import {
    name: "NTCamera",
    owner: "nothing",
    apk: "proprietary/system_ext/priv-app/NTCamera/NTCamera.apk",
    certificate: "platform",
    dex_preopt: {
        enabled: false,
    },
    privileged: true,
    system_ext_specific: true,
}

android_app_import {
    name: "NothingExperience",
    owner: "nothing",
    apk: "proprietary/system_ext/priv-app/NothingExperience/NothingExperience.apk",
    certificate: "platform",
    dex_preopt: {
        enabled: false,
    },
    privileged: true,
    system_ext_specific: true,
}
