cc_prebuilt_binary {
    name: "vendor.noth.hardware.camera-service",
    owner: "nothing",
    target: {
        android_arm64: {
            srcs: [
                "proprietary/vendor/bin/hw/vendor.noth.hardware.camera-service",
            ],
            shared_libs: [
                "libc++",
                "libcutils",
                "liblog",
                "libsync",
                "libui",
                "libbase",
                "libhidlbase",
                "libbinder_ndk",
