<?xml version="1.0" encoding="utf-8"?>
<permissions>

    <!-- NothingProxy: platform proxy service requiring signature-level permissions.
         All entries mirror what is declared in the app's AndroidManifest.xml.
         Without this file, PackageManager silently drops all undeclared
         priv-app permissions, causing runtime SecurityExceptions. -->
    <privapp-permissions package="com.nothing.proxy">
        <permission name="android.permission.DEVICE_POWER"/>
        <permission name="android.permission.READ_DEVICE_CONFIG"/>
        <permission name="android.permission.INTERACT_ACROSS_USERS"/>
        <permission name="android.permission.INTERACT_ACROSS_USERS_FULL"/>
        <permission name="android.permission.MODIFY_PHONE_STATE"/>
        <permission name="android.permission.SET_WALLPAPER_COMPONENT"/>
        <permission name="android.permission.MANAGE_MEDIA_PROJECTION"/>
        <permission name="android.permission.BLUETOOTH_PRIVILEGED"/>
        <permission name="android.permission.FORCE_STOP_PACKAGES"/>
        <permission name="android.permission.DELETE_PACKAGES"/>
        <permission name="android.permission.REQUEST_DELETE_PACKAGES"/>
        <permission name="android.permission.CONTROL_INCALL_EXPERIENCE"/>
        <permission name="android.permission.MANAGE_EXTERNAL_STORAGE"/>
        <permission name="android.permission.MANAGE_APP_OPS_MODES"/>
        <permission name="android.permission.MANAGE_USERS"/>
        <permission name="android.permission.MAINLINE_NETWORK_STACK"/>
        <permission name="android.permission.NETWORK_SETTINGS"/>
        <permission name="android.permission.OVERRIDE_WIFI_CONFIG"/>
        <permission name="android.permission.SCHEDULE_EXACT_ALARM"/>
    </privapp-permissions>

</permissions>
